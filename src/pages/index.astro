---
import DesktopLayout from '../layouts/DesktopLayout.astro';
import Desktop from '../components/desktop/Desktop.astro';
import MobileFallback from '../components/desktop/MobileFallback.astro';
import CommandPalette from '../components/desktop/CommandPalette.astro';
import HelpOverlay from '../components/desktop/HelpOverlay.astro';
import ResetConfirm from '../components/desktop/ResetConfirm.astro';
import ShutdownOverlay from '../components/desktop/ShutdownOverlay.astro';
import { profile } from '../data/profile';

const canonical = 'https://millsymills.com/';
// Reuse the about.exe OG card — its copy ("mills — corporate security
// engineer @ Trail of Bits…") is exactly the framing we want as the
// social preview for the landing desktop.
const ogImage = 'https://millsymills.com/og/about.png';
---

<DesktopLayout
	title={profile.handle}
	description={`${profile.title} @ ${profile.currentEmployer}. portfolio + links.`}
	canonical={canonical}
	ogUrl={canonical}
	ogImage={ogImage}
>
	<Desktop />
	<MobileFallback />
	<CommandPalette />
	<HelpOverlay />
	<ResetConfirm />
	<ShutdownOverlay />
</DesktopLayout>
