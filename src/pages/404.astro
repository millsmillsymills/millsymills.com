---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — millsymills.com" noindex>
	<div class="not-found">
		<img
			class="not-found__hero"
			src="/images/icons/vaporwave/error-404.png"
			alt="ERROR 404 — page not found"
			width="464"
			height="320"
		/>
		<p class="not-found__msg">the page you're looking for doesn't exist.</p>
		<p><a class="not-found__home" href="/">← go home</a></p>
	</div>
</BaseLayout>

<style is:global>
	body:has(.not-found) {
		background: #1a0e23;
		color: #ffd6ec;
	}
</style>

<style>
	.not-found {
		/* dvh keeps the layout from overflowing if BaseLayout ever grows
		 * a header/footer. 100vh would force a scrollbar in that case. */
		min-height: 100dvh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 24px;
		padding: 32px;
		text-align: center;
		font-family: 'VT323', 'Courier New', monospace;
	}

	.not-found__hero {
		/* Cap at the asset's intrinsic 464px so it doesn't upscale and lose
		 * pixel-art crispness on wide monitors; still scales down on phones. */
		max-width: min(464px, 90vw);
		width: 100%;
		height: auto;
		image-rendering: pixelated;
		filter: drop-shadow(4px 4px 0 #321a44);
	}

	.not-found__msg {
		font-size: 22px;
		margin: 0;
	}

	.not-found__home {
		display: inline-block;
		padding: 8px 16px;
		background: #ff7ec0;
		color: #1a0e23;
		border: 2px solid #321a44;
		border-radius: 4px;
		box-shadow: 2px 2px 0 0 #321a44;
		text-decoration: none;
		font-family: 'Press Start 2P', 'VT323', monospace;
		font-size: 12px;
		transition: transform 80ms ease;
	}

	.not-found__home:hover,
	.not-found__home:focus-visible {
		background: #ff4fa8;
		color: #fff9f3;
	}

	.not-found__home:active {
		transform: translate(1px, 1px);
	}
</style>
