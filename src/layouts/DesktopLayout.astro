---
import '../styles/desktop.css';
import { profile } from '../data/profile';

interface Props {
	title: string;
	description?: string;
	canonical?: string;
	ogUrl?: string;
	/** App id to auto-open on load (overrides localStorage + ?open=). */
	initialOpen?: string;
}

const { title, description, canonical, ogUrl, initialOpen } = Astro.props;

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Person',
			'@id': 'https://millsymills.com/#mills',
			name: profile.name,
			alternateName: profile.handle,
			jobTitle: profile.title,
			worksFor: { '@type': 'Organization', name: profile.currentEmployer },
			address: { '@type': 'PostalAddress', addressLocality: 'Seattle', addressRegion: 'WA' },
			email: `mailto:${profile.email}`,
			url: 'https://millsymills.com/',
			sameAs: [profile.github],
		},
		{
			'@type': 'WebSite',
			'@id': 'https://millsymills.com/#website',
			url: 'https://millsymills.com/',
			name: 'millsymills.com',
			description: 'mills — corporate security engineer. portfolio + links.',
			author: { '@id': 'https://millsymills.com/#mills' },
			license: 'https://github.com/millsmillsymills/millsymills.com/blob/main/LICENSE',
		},
	],
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="millsymills.com" />
		{ogUrl && <meta property="og:url" content={ogUrl} />}

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap"
		/>

		{/* Agent-readable side-channels (Cloudflare isitagentready.com pattern) */}
		<link rel="alternate" type="text/markdown" href="/llms.txt" title="llms.txt summary" />
		<link rel="alternate" type="text/markdown" href="/llms-full.txt" title="llms-full.txt (full content)" />
		<link rel="sitemap" type="application/xml" href="/sitemap.xml" />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<title>{title}</title>
	</head>
	<body data-initial-open={initialOpen}>
		<!-- flag{html_comments_have_no_secrets} -->
		<slot />
		<div class="boot-overlay" aria-hidden="true"></div>
		<script>
			import '../scripts/window-manager';
			import '../scripts/boot';
			import {
				consoleBanner,
				konami,
				submitFlag,
				getCaptured,
				captureById,
			} from '../scripts/flags';
			consoleBanner();
			konami();
			// Expose a tiny API so devtools-savvy visitors can play with flags
			// outside the terminal. Read-only by intent.
			(window as unknown as { mills: unknown }).mills = {
				flag: { submit: submitFlag, status: getCaptured, capture: captureById },
			};
		</script>
	</body>
</html>
