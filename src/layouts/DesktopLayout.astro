---
import '../styles/desktop.css';
import { profile } from '../data/profile';
import Clippy from '../components/desktop/Clippy.astro';
import { serializeJsonForScript } from '../scripts/util/html';

interface Props {
	title: string;
	description?: string;
	canonical?: string;
	ogUrl?: string;
	ogImage?: string;
	noindex?: boolean;
	/** App id to auto-open on load (overrides localStorage + ?open=). */
	initialOpen?: string;
}

const { title, description, canonical, ogUrl, ogImage, noindex, initialOpen } = Astro.props;

const siteHref = 'https://millsymills.com/';

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Person',
			'@id': `${siteHref}#mills`,
			name: profile.name,
			alternateName: profile.handle,
			jobTitle: profile.title,
			worksFor: { '@type': 'Organization', name: profile.currentEmployer },
			address: { '@type': 'PostalAddress', addressLocality: 'Seattle', addressRegion: 'WA' },
			// Email omitted intentionally — surfaced only via the PoW-gated reveal
			// on /mail/ to keep it out of static html (and out of structured-data
			// scrapers that hoover JSON-LD).
			url: siteHref,
			sameAs: [profile.github],
		},
		{
			'@type': 'WebSite',
			'@id': `${siteHref}#website`,
			url: siteHref,
			name: 'millsymills.com',
			description: 'mills — corporate security engineer. portfolio + links.',
			author: { '@id': `${siteHref}#mills` },
			license: 'https://github.com/millsmillsymills/millsymills.com/blob/main/LICENSE',
		},
	],
};

// `JSON.stringify` alone would let `</script>`, `<!--`, or `-->` substrings
// slip into the inline script body unescaped (defense-in-depth — no field is
// user-controlled today, but `serializeJsonForScript` escapes `<`, `>`, `&`,
// U+2028, U+2029 to JSON unicode escapes so the JSON-LD blob can't be turned
// into a parser-confusion XSS sink by a future careless content edit).
const jsonLdSerialized = serializeJsonForScript(jsonLd);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="millsymills.com" />
		{ogUrl && <meta property="og:url" content={ogUrl} />}
		{ogImage && <meta property="og:image" content={ogImage} />}
		{ogImage && <meta property="og:image:type" content="image/png" />}
		{ogImage && <meta property="og:image:width" content="1200" />}
		{ogImage && <meta property="og:image:height" content="630" />}

		{/* for agents + devtools spelunkers — decode the token, submit the flag. */}
		<meta name="x-mills-token" content="ZmxhZ3tiYXNlX3NpeHR5X2ZvdXJfaXNfYV9jbGFzc2ljfQ==" />

		{/* Agent-readable side-channels (Cloudflare isitagentready.com pattern) */}
		<link rel="alternate" type="text/markdown" href="/llms.txt" title="llms.txt summary" />
		<link rel="alternate" type="text/markdown" href="/llms-full.txt" title="llms-full.txt (full content)" />
		<link rel="sitemap" type="application/xml" href="/sitemap.xml" />

		{/* Preload Clippy's idle sprite — first paint right after boot needs it
		    and the boot animation gives the network a head-start. */}
		<link rel="preload" as="image" href="/clippy/idle.png" />

		<script is:inline type="application/ld+json" set:html={jsonLdSerialized} />

		{/* Theme + wallpaper bootstrap — must run before .desktop's first paint
		    so <html data-theme> and background-image's `var(--desktop-bg)`
		    resolve to the user's choices from the first frame. Lives in
		    <head> (auto-deferred module) for that reason; picker UI
		    handlers load later from inside Display.astro. */}
		<script>
			import '../scripts/theme-init';
			import '../scripts/wallpaper-init';
		</script>

		<title>{title}</title>
	</head>
	<body data-initial-open={initialOpen}>
		<!-- flag{html_comments_have_no_secrets} -->
		<div class="motif-grain" aria-hidden="true"></div>
		<slot />
		<Clippy />
		<div class="boot-overlay" aria-hidden="true"></div>
		<script>
			import '../scripts/window-manager';
			import '../scripts/boot';
			import {
				consoleBanner,
				konami,
				submitFlag,
				getCaptured,
				captureById,
				initFlagsUI,
			} from '../scripts/flags';
			import { initMailPow } from '../scripts/mail-pow';
			// initFlagsUI is the FIRST thing that runs — it sets
			// body[data-flags-unlocked] from localStorage so users with
			// captures don't see a flash of locked-state UI on reload.
			initFlagsUI();
			consoleBanner();
			konami();
			initMailPow();
			// Expose a tiny API so devtools-savvy visitors can play with flags
			// outside the terminal. Read-only by intent. Key names here
			// (submit/status/capture) are advertised in `consoleBanner` —
			// rename in lockstep, no compile-time link.
			//
			// Merge into window.mills rather than overwrite — reset.ts and
			// clippy.ts already register `__resetInit` / `__clippyInit`
			// idempotency flags on the same namespace, and a wholesale
			// reassignment here would clobber them depending on init order.
			Object.assign((window.mills ??= {}), {
				flag: { submit: submitFlag, status: getCaptured, capture: captureById },
			});
		</script>
	</body>
</html>
