---
import About from './apps/About.astro';
import Resume from './apps/Resume.astro';
import Photos from './apps/Photos.astro';
import Mail from './apps/Mail.astro';
import Flags from './apps/Flags.astro';
import Music from './apps/Music.astro';
import Memes from './apps/Memes.astro';
import Trash from './apps/Trash.astro';
import Projects from './apps/Projects.astro';
import Uses from './apps/Uses.astro';
import Stub from './apps/Stub.astro';
import { profile } from '../../data/profile';
import { apps } from '../../data/apps';

const contentFor = (id: string) => {
	switch (id) {
		case 'about':
			return About;
		case 'resume':
			return Resume;
		case 'photos':
			return Photos;
		case 'mail':
			return Mail;
		case 'flags':
			return Flags;
		case 'music':
			return Music;
		case 'memes':
			return Memes;
		case 'trash':
			return Trash;
		case 'projects':
			return Projects;
		case 'uses':
			return Uses;
		default:
			return null;
	}
};
---

<div class="mshell">
	<div class="mshell__statusbar">
		<span class="mshell__sparkles" aria-hidden="true">✦ ✧ ⋆</span>
		<span class="mshell__clock" aria-label="current time">--:--</span>
	</div>

	<section class="mshell__home">
		<header class="mshell__home-hero">
			<h1>{profile.handle}</h1>
			<p>{profile.title} @ {profile.currentEmployer}</p>
		</header>

		<ul class="mshell__grid">
			{
				apps.map((a) => (
					<li>
						<button
							type="button"
							class="mshell-icon"
							data-open-app={a.id}
							data-title={a.title}
						>
							<span class="mshell-icon__glyph" aria-hidden="true">
								{a.glyph}
							</span>
							<span class="mshell-icon__label">{a.label}</span>
						</button>
					</li>
				))
			}
		</ul>
	</section>

	<section class="mshell__app-view" hidden>
		<header class="mshell__app-chrome">
			<button type="button" class="mshell__chrome-back" aria-label="back to home">
				← home
			</button>
			<span class="mshell__chrome-title"></span>
		</header>
		<div class="mshell__app-body">
			{
				apps.map((a) => {
					const Content = contentFor(a.id);
					return (
						<div data-mobile-app={a.id} hidden>
							{Content && <Content />}
							{!Content && a.id === 'terminal' && (
								<Stub
									title="terminal"
									note="terminal needs a real keyboard — open this site on a wider screen to play. flags.exe works fine here though."
								/>
							)}
							{!Content && a.id !== 'terminal' && <Stub title={a.label} />}
						</div>
					);
				})
			}
		</div>
	</section>
</div>

<script>
	import '../../scripts/mobile-shell';
</script>
