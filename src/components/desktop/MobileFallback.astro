---
import { profile } from '../../data/profile';
import { apps, iconSpriteStyle } from '../../data/apps';

const MSHELL_ICON_PX = 56;
---

<div class="mshell">
	<div class="mshell__statusbar">
		<span class="mshell__sparkles" aria-hidden="true">✦ ✧ ⋆</span>
		<span class="mshell__clock" aria-label="current time">--:--</span>
	</div>

	<section class="mshell__home">
		<header class="mshell__home-hero">
			<h1>{profile.handle}</h1>
			<p>{profile.title} @ {profile.currentEmployer}</p>
		</header>

		<ul class="mshell__grid">
			{
				apps.filter((a) => !a.desktopOnly && !a.hidden).map((a) => (
					<li>
						<button
							type="button"
							class="mshell-icon"
							data-open-app={a.id}
							data-title={a.title}
						>
							{
								a.iconSprite ? (
									<span
										class="mshell-icon__sprite"
										style={iconSpriteStyle(a.iconSprite, MSHELL_ICON_PX)}
										aria-hidden="true"
									/>
								) : a.iconUrl ? (
									<img class="mshell-icon__icon" src={a.iconUrl} alt="" aria-hidden="true" />
								) : (
									<span class="mshell-icon__glyph" aria-hidden="true">{a.glyph}</span>
								)
							}
							<span class="mshell-icon__label">{a.label}</span>
						</button>
					</li>
				))
			}
		</ul>
	</section>

	{/* App-view containers are empty placeholders. mobile-shell.ts moves
	    each app's body in from the corresponding Desktop window on the
	    mobile breakpoint (and back again on resize past 768px). Keeping
	    a single SSR per app body is what avoids duplicate `id` attrs in
	    `dist/` — see #519. */}
	<section class="mshell__app-view" hidden>
		<header class="mshell__app-chrome">
			<button type="button" class="mshell__chrome-back" aria-label="back to home">
				← home
			</button>
			<span class="mshell__chrome-title"></span>
		</header>
		<div class="mshell__app-body">
			{
				apps.filter((a) => !a.desktopOnly && !a.hidden).map((a) => (
					<div data-mobile-app={a.id} hidden />
				))
			}
		</div>
	</section>
</div>

<script>
	import '../../scripts/mobile-shell';
</script>
