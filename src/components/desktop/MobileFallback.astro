---
import About from './apps/About.astro';
import Resume from './apps/Resume.astro';
import Photos from './apps/Photos.astro';
import Mail from './apps/Mail.astro';
import Flags from './apps/Flags.astro';
import Stub from './apps/Stub.astro';
import { profile } from '../../data/profile';

// Same icon set as the desktop, minus terminal (no real keyboard) and
// trash (a desktop-only joke). Order intentionally mirrors desktop.
const apps = [
	{ id: 'about', label: 'about', glyph: '🪪', title: 'about.exe', component: 'about' },
	{ id: 'resume', label: 'resume', glyph: '📄', title: 'resume.txt', component: 'resume' },
	{ id: 'photos', label: 'photos', glyph: '🖼️', title: 'photos/', component: 'photos' },
	{ id: 'flags', label: 'flags', glyph: '🚩', title: 'flags.exe', component: 'flags' },
	{ id: 'mail', label: 'mail', glyph: '✉️', title: 'mail.exe', component: 'mail' },
	{ id: 'terminal', label: 'terminal', glyph: '⌨️', title: 'terminal', component: 'terminal' },
	{ id: 'music', label: 'music', glyph: '💿', title: 'winamp.exe', component: 'stub' },
	{ id: 'memes', label: 'memes', glyph: '🗂️', title: 'memes/', component: 'stub' },
];
---

<div class="mshell">
	<div class="mshell__statusbar">
		<span class="mshell__sparkles" aria-hidden="true">✦ ✧ ⋆</span>
		<span class="mshell__clock" aria-label="current time">--:--</span>
	</div>

	<section class="mshell__home">
		<header class="mshell__home-hero">
			<h1>{profile.handle}</h1>
			<p>{profile.title} @ {profile.currentEmployer}</p>
		</header>

		<ul class="mshell__grid">
			{
				apps.map((a) => (
					<li>
						<button
							type="button"
							class="mshell-icon"
							data-open-app={a.id}
							data-title={a.title}
						>
							<span class="mshell-icon__glyph" aria-hidden="true">
								{a.glyph}
							</span>
							<span class="mshell-icon__label">{a.label}</span>
						</button>
					</li>
				))
			}
		</ul>
	</section>

	<section class="mshell__app-view" hidden>
		<header class="mshell__app-chrome">
			<button type="button" class="mshell__chrome-back" aria-label="back to home">
				← home
			</button>
			<span class="mshell__chrome-title"></span>
		</header>
		<div class="mshell__app-body">
			{
				apps.map((a) => (
					<div data-mobile-app={a.id} hidden>
						{a.component === 'about' && <About />}
						{a.component === 'resume' && <Resume />}
						{a.component === 'photos' && <Photos />}
						{a.component === 'flags' && <Flags />}
						{a.component === 'mail' && <Mail />}
						{a.component === 'terminal' && (
							<Stub
								title="terminal"
								note="terminal needs a real keyboard — open this site on a wider screen to play. flags.exe works fine here though."
							/>
						)}
						{a.component === 'stub' && <Stub title={a.label} />}
					</div>
				))
			}
		</div>
	</section>
</div>

<script>
	import '../../scripts/mobile-shell';
</script>
