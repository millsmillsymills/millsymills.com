---
import { profile } from '../../../data/profile';
import { pgp } from '../../../data/pgp';
---

<style>
	.about {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: 16px;
	}

	.about__avatar-stack {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
	}

	.about__avatar {
		width: 120px;
		height: 120px;
		object-fit: cover;
		background: var(--lilac-100);
		border: 2px solid var(--border);
		border-radius: 8px;
	}

	.about__online {
		width: 120px;
		height: auto;
		image-rendering: pixelated;
		filter: drop-shadow(0 0 6px rgba(0, 229, 255, 0.45));
	}

	.about__avatar--placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-pixel);
		font-size: 11px;
		text-align: center;
		color: var(--ink-soft);
		padding: 6px;
	}

	/* User-agent `[hidden] { display: none }` is otherwise lost to the
	   explicit `display: flex` above. Without this, the placeholder
	   stays visible alongside a successfully-loaded headshot. */
	.about__avatar--placeholder[hidden] {
		display: none;
	}

	.about__name {
		font-family: var(--font-xp-display);
		font-style: italic;
		font-size: 28px;
		font-weight: 400;
		text-transform: lowercase;
		letter-spacing: 0.3px;
		color: var(--ink-primary);
		text-shadow: 0 0 6px rgba(255, 79, 168, 0.25);
		margin: 0 0 6px;
	}

	.about__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 4px 8px;
		font-family: var(--font-pixel);
		font-size: 9px;
		color: var(--ink-soft);
		margin: 0 0 8px;
	}

	.about__meta span {
		padding: 2px 6px;
		background: var(--lilac-100);
		border: 1px solid var(--lilac-300);
		border-radius: 3px;
	}

	.about__mail-link[data-pow-state='solving'] {
		color: var(--ink-soft);
		font-style: italic;
	}

	.about__keys {
		margin-top: 0.6rem;
		font-size: 0.82rem;
		color: var(--ink-soft);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
	}
	.about__keys-label {
		font-family: var(--font-pixel);
		font-size: 9px;
		padding: 2px 6px;
		background: var(--lilac-100);
		border: 1px solid var(--lilac-300);
		border-radius: 3px;
	}
	.about__keys-fp {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		background: var(--pink-50);
		padding: 0.1rem 0.35rem;
		border-radius: 2px;
		word-break: break-all;
	}

	@media (max-width: 460px) {
		.about {
			grid-template-columns: 1fr;
		}
	}
</style>

<article class="about">
	<div class="about__avatar-stack">
		<img
			class="about__avatar"
			src="/images/headshot.jpg"
			alt={`${profile.name} headshot`}
			loading="lazy"
			decoding="async"
		/>
		<div class="about__avatar about__avatar--placeholder" hidden>
			headshot.jpg pending — drop into public/images/
		</div>
		<img
			class="about__online"
			src="/images/icons/vaporwave/online.png"
			alt="online — mills is reachable"
			width="772"
			height="378"
			loading="lazy"
			decoding="async"
		/>
	</div>
	<div>
		<h1 class="about__name">{profile.name}</h1>
		<p class="about__meta">
			{profile.certifications.map((c) => <span>{c}</span>)}
		</p>
		<p class="about__meta">
			<span>{profile.pronouns}</span>
			<span>{profile.location}</span>
		</p>
		<p>
			<strong>{profile.title}</strong> @ {profile.currentEmployer}.
		</p>
		<p>{profile.summary}</p>
		<p>
			<a
				data-mail-pow-link
				data-mail-subject="hi from millsymills.com"
				href="#"
				data-pow-state="solving"
				class="about__mail-link"
				>solving proof-of-work…</a
			>
			·
			<a href={profile.github}>github</a>
			·
			<a href={profile.githubOrg}>github org</a>
		</p>
		<p class="about__keys">
			<span class="about__keys-label">pgp</span>
			<code class="about__keys-fp">{pgp.fingerprint}</code>
			<a href={pgp.downloadPath} download>{pgp.downloadPath}</a>
		</p>
		{pgp.age && (
			<p class="about__keys">
				<span class="about__keys-label">age</span>
				<code class="about__keys-fp">{pgp.age.recipient}</code>
				<a href={pgp.ageDownloadPath} download>{pgp.ageDownloadPath}</a>
			</p>
		)}
	</div>
</article>

<script>
	import '../../../scripts/about-avatar-fallback';
</script>
