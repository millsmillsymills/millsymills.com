---
import { profile } from '../../../data/profile';
import { pgp } from '../../../data/pgp';
---

<style>
	.about {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: 16px;
	}

	.about__avatar {
		width: 120px;
		height: 120px;
		object-fit: cover;
		background: var(--lilac-100);
		border: 2px solid var(--border);
		border-radius: 8px;
	}

	.about__avatar--placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-pixel);
		font-size: 11px;
		text-align: center;
		color: var(--ink-soft);
		padding: 6px;
	}

	.about__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 4px 8px;
		font-family: var(--font-pixel);
		font-size: 9px;
		color: var(--ink-soft);
		margin: 0 0 8px;
	}

	.about__meta span {
		padding: 2px 6px;
		background: var(--lilac-100);
		border: 1px solid var(--lilac-300);
		border-radius: 3px;
	}

	.about__mail-link[data-pow-state='solving'] {
		color: var(--ink-soft);
		font-style: italic;
	}

	.about__keys {
		margin-top: 0.6rem;
		font-size: 0.82rem;
		color: var(--ink-soft);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
	}
	.about__keys-label {
		font-family: var(--font-pixel);
		font-size: 9px;
		padding: 2px 6px;
		background: var(--lilac-100);
		border: 1px solid var(--lilac-300);
		border-radius: 3px;
	}
	.about__keys-fp {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		background: var(--pink-50);
		padding: 0.1rem 0.35rem;
		border-radius: 2px;
		word-break: break-all;
	}

	@media (max-width: 460px) {
		.about {
			grid-template-columns: 1fr;
		}
	}
</style>

<article class="about">
	<img
		class="about__avatar"
		src="/images/headshot.jpg"
		alt={`${profile.name} headshot`}
		loading="lazy"
		decoding="async"
	/>
	<div class="about__avatar about__avatar--placeholder" hidden>
		headshot.jpg pending — drop into public/images/
	</div>
	<div>
		<h1>{profile.name}</h1>
		<p class="about__meta">
			{profile.certifications.map((c) => <span>{c}</span>)}
		</p>
		<p class="about__meta">
			<span>{profile.pronouns}</span>
			<span>{profile.location}</span>
		</p>
		<p>
			<strong>{profile.title}</strong> @ {profile.currentEmployer}.
		</p>
		<p>{profile.summary}</p>
		<p>
			<a
				data-mail-pow-link
				data-mail-subject="hi from millsymills.com"
				href="#"
				data-pow-state="solving"
				class="about__mail-link"
				>solving proof-of-work…</a
			>
			·
			<a href={profile.github}>github</a>
		</p>
		<p class="about__keys">
			<span class="about__keys-label">pgp</span>
			<code class="about__keys-fp">{pgp.fingerprint}</code>
			<a href={pgp.downloadPath} download>{pgp.downloadPath}</a>
		</p>
	</div>
</article>

<script>
	// CSP forbids inline `onerror=` (script-src 'self' with no 'unsafe-inline'),
	// so the placeholder swap has to be wired up here. If the avatar 404s,
	// hide it and reveal the sibling `.about__avatar--placeholder` div.
	function init() {
		document.querySelectorAll<HTMLImageElement>('img.about__avatar').forEach((img) => {
			const placeholder = img.nextElementSibling as HTMLElement | null;
			if (!placeholder?.classList.contains('about__avatar--placeholder')) return;
			const swap = () => {
				img.hidden = true;
				placeholder.removeAttribute('hidden');
			};
			// If the image already failed before we bound (cached 404, fast network),
			// `complete` is true and `naturalWidth` is 0. Trigger the swap manually.
			if (img.complete && img.naturalWidth === 0) swap();
			else img.addEventListener('error', swap, { once: true });
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>
