---
import { photos } from '../../../data/profile';
---

<style>
	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
		gap: 12px;
	}

	.gallery figure {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.gallery img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border: 2px solid var(--border);
		border-radius: 6px;
		background: var(--lilac-100);
	}

	.gallery figcaption {
		font-family: var(--font-pixel);
		font-size: 9px;
		color: var(--ink-soft);
		text-align: center;
	}
</style>

<h1>photos/</h1>

<p style="color:var(--ink-soft);font-size:16px">
	the cats. drop the real files into <code>public/images/cats/</code> and update names in <code
		>src/data/profile.ts</code
	>.
</p>

<div class="gallery">
	{
		photos.map((p) => (
			<figure>
				<img src={p.src} alt={p.alt} loading="lazy" decoding="async" />
				<figcaption>{p.caption}</figcaption>
			</figure>
		))
	}
</div>
