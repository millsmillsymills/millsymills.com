<style>
	.trash__intro {
		font-family: var(--font-screen);
		font-size: 17px;
		color: var(--ink-soft);
		margin: 0 0 12px;
	}

	.trash__list {
		list-style: none;
		margin: 0 0 16px;
		padding: 0;
		border: 2px solid var(--border);
		border-radius: 4px;
		overflow: hidden;
	}

	.trash__row {
		display: grid;
		grid-template-columns: 28px 1fr auto auto;
		align-items: center;
		gap: 10px;
		padding: 6px 10px;
		font-family: var(--font-mono);
		font-size: 13px;
		border-bottom: 1px solid var(--lilac-300);
		cursor: default;
	}

	.trash__row:last-child {
		border-bottom: none;
	}

	.trash__row.trash__row--clickable {
		cursor: pointer;
	}

	.trash__row.trash__row--clickable:hover {
		background: var(--pink-100);
	}

	.trash__glyph {
		text-align: center;
	}

	.trash__name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.trash__size,
	.trash__date {
		font-size: 12px;
		color: var(--ink-soft);
	}

	.trash__viewer {
		margin: 0;
		padding: 12px 14px;
		background: #0e0214;
		color: #c8a8ff;
		border: 2px solid var(--border);
		border-radius: 4px;
		font-family: var(--font-mono);
		font-size: 12px;
		line-height: 1.5;
		max-height: 220px;
		overflow: auto;
		white-space: pre;
	}

	.trash__viewer .t-flag {
		color: #ffd6ec;
		background: rgba(255, 79, 168, 0.18);
	}

	.trash__hint {
		margin: 12px 0 0;
		font-family: var(--font-pixel);
		font-size: 10px;
		color: var(--ink-soft);
	}
</style>

