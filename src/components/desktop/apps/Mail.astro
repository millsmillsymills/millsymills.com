---
import { profile } from '../../../data/profile';
import { pgp } from '../../../data/pgp';
---

<h1>mail.exe</h1>

<p>
	the contact form is a <code>mailto:</code> for now. swap to formspree / SES + lambda later.
</p>

<p class="mail-row">
	<a
		data-mail-pow-link
		data-mail-subject="hi from millsymills.com"
		href="#"
		data-pow-state="solving"
		class="mail-link"
		>→ <span class="mail-spinner">solving proof-of-work…</span></a
	>
	<button type="button" data-mail-pow-reveal class="mail-fallback" hidden>reveal email</button>
</p>

<noscript>
	<p class="mail-noscript">
		javascript is required to reveal the address — a small proof-of-work
		gate keeps it out of the static html so casual scrapers don't get a
		free <code>mailto:</code>. without js, ping mills via <a href={profile.github}>github</a>
		instead.
	</p>
</noscript>

<p class="pgp">
	encrypt: <code>{pgp.fingerprint}</code>
	&nbsp;·&nbsp;
	<a href="/pgp.asc" download>download /pgp.asc</a>
</p>

<p>
	or shout into the void on <a href={profile.github}>github</a>.
</p>

<style>
	.mail-row {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.mail-link {
		font-size: 24px;
	}
	.mail-spinner {
		color: var(--ink-soft);
		font-style: italic;
	}
	.mail-fallback {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		padding: 0.2rem 0.55rem;
		background: var(--pink-50);
		color: var(--pink-600);
		border: 1px solid var(--pink-300);
		border-radius: 3px;
		cursor: pointer;
	}
	.mail-fallback:disabled {
		opacity: 0.6;
		cursor: progress;
	}
	.mail-noscript {
		color: var(--ink-soft);
		font-size: 0.85rem;
	}
	.pgp {
		margin-top: 0.3rem;
		font-size: 0.85rem;
		color: var(--ink-soft);
	}
	.pgp code {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		background: var(--pink-50);
		padding: 0.1rem 0.35rem;
		border-radius: 2px;
		word-break: break-all;
	}
</style>
