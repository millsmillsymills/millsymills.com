---
import { profile } from '../../../data/profile';
import { pgp } from '../../../data/pgp';

const subject = encodeURIComponent('hi from millsymills.com');
const body = encodeURIComponent('');
---

<h1>mail.exe</h1>

<p>
	the contact form is a <code>mailto:</code> for now. swap to formspree / SES + lambda later.
</p>

<p>
	<a href={`mailto:${profile.email}?subject=${subject}&body=${body}`} style="font-size:24px"
		>→ {profile.email}</a
	>
</p>

<p class="pgp">
	encrypt: <code>{pgp.fingerprint}</code>
	&nbsp;·&nbsp;
	<a href="/pgp.asc" download>download /pgp.asc</a>
</p>

<p>
	or shout into the void on <a href={profile.github}>github</a>.
</p>

<style>
	.pgp {
		margin-top: 0.3rem;
		font-size: 0.85rem;
		color: var(--ink-soft);
	}
	.pgp code {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		background: var(--pink-50);
		padding: 0.1rem 0.35rem;
		border-radius: 2px;
		word-break: break-all;
	}
</style>
