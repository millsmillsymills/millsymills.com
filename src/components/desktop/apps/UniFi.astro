---
// unifi-mcp live demo.
//
// The demo is a self-contained vanilla HTML/CSS/JS app that lives under
// `public/apps/unifi-demo/` and is embedded here in an iframe so its own
// styles + scripts stay isolated from the desktop shell. It makes NO
// third-party requests — the one webfont it used (JetBrains Mono via
// Google Fonts) was swapped for a self-hosted/system monospace stack so
// the app stays within the site's no-third-party / strict-CSP posture.
//
// The iframe src is assigned on first window-open so the demo's scripts
// don't run for every visitor who never opens the window. The trigger is
// the window-manager's canonical `mills:window-open` event, which fires on
// every open path (launcher click, session restore, ?open= deep-link), so
// the load can't be missed.
---

<div class="unifi-demo">
	<iframe
		class="unifi-demo__frame"
		data-unifi-src="/apps/unifi-demo/index.html"
		title="unifi-mcp live demo"
		loading="lazy"
	></iframe>
</div>

<style>
	.unifi-demo {
		width: 100%;
		height: 100%;
		display: flex;
		background: var(--bg-void);
	}

	.unifi-demo__frame {
		flex: 1 1 auto;
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}
</style>

<script>
	function init(): void {
		const win = document.querySelector<HTMLElement>('[data-window-id="unifi"]');
		const frame = document.querySelector<HTMLIFrameElement>('.unifi-demo__frame');
		if (!win || !frame) return;

		let loaded = false;
		const load = (): void => {
			if (loaded) return;
			loaded = true;
			const src = frame.dataset.unifiSrc;
			if (src) frame.src = src;
		};

		// Subscribe to the window-manager's open event for future opens; the
		// initial !hidden check covers a window restored open before this
		// listener registers, where the event has already fired.
		window.addEventListener('mills:window-open', (event) => {
			if (event.detail.id === 'unifi') load();
		});
		if (!win.hidden) load();
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>
