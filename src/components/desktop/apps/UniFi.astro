---
// unifi-mcp live demo.
//
// The demo is a self-contained vanilla HTML/CSS/JS app that lives under
// `public/apps/unifi-demo/` and is embedded here in an iframe so its own
// styles + scripts stay isolated from the desktop shell. It makes NO
// third-party requests — the one webfont it used (JetBrains Mono via
// Google Fonts) was swapped for a self-hosted/system monospace stack so
// the app stays within the site's no-third-party / strict-CSP posture.
//
// The iframe src is assigned on first reveal so the demo's scripts don't
// run for every visitor who never opens the window. The trigger is a
// MutationObserver on the window's `hidden` attribute — the canonical
// "just opened" signal that fires on both the desktop window-manager and
// the mobile shell (see src/scripts/unifi-demo.ts).
---

<div class="unifi-demo">
	<iframe
		class="unifi-demo__frame"
		data-unifi-src="/apps/unifi-demo/index.html"
		title="unifi-mcp live demo"
		loading="lazy"
	></iframe>
</div>

<style>
	.unifi-demo {
		width: 100%;
		height: 100%;
		display: flex;
		background: var(--bg-void);
	}

	.unifi-demo__frame {
		flex: 1 1 auto;
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}
</style>

<script>
	// Imported (not inlined) so Astro bundles it to an external `_astro/*.js`
	// covered by `script-src 'self'`. A self-contained inline script would ship
	// a hash the prod CloudFront CSP doesn't allowlist and get blocked (#645).
	import '../../../scripts/unifi-demo';
</script>
