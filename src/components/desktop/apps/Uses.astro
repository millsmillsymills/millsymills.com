---
import { chimera, gear } from '../../../data/uses';
import { tools, toolCategoryTitles, toolCategoryOrder } from '../../../data/tools';

const toolsByCategory = toolCategoryOrder
	.map((cat) => ({
		cat,
		title: toolCategoryTitles[cat],
		items: tools.filter((t) => t.category === cat),
	}))
	.filter((group) => group.items.length > 0); // skip empty categories (matches terminal behavior)
---

<style>
	.uses__intro {
		font-family: var(--font-screen);
		font-size: 17px;
		color: var(--ink-soft);
		margin: 0 0 18px;
	}

	.chimera {
		background: #0e0214;
		color: #ffd6ec;
		border: 2px solid var(--border);
		border-radius: 6px;
		padding: 14px 16px;
		margin: 0 0 20px;
		font-family: var(--font-mono);
		font-size: 13px;
		line-height: 1.5;
	}

	.chimera__header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 10px;
		margin-bottom: 10px;
		padding-bottom: 8px;
		border-bottom: 1px dashed #6ea8ff;
	}

	.chimera__name {
		font-family: var(--font-pixel);
		font-size: 14px;
		color: #ff7ec0;
		letter-spacing: 2px;
	}

	.chimera__role {
		color: #c8a8ff;
		font-size: 12px;
	}

	.chimera__specs {
		display: grid;
		grid-template-columns: max-content 1fr;
		gap: 4px 14px;
		margin: 0;
	}

	.chimera__specs dt {
		color: #9a7fb8;
		text-transform: uppercase;
		font-size: 10px;
		letter-spacing: 1px;
		padding-top: 2px;
	}

	.chimera__specs dd {
		color: #ffd6ec;
		margin: 0;
	}

	.uses-group {
		margin: 0 0 20px;
	}

	.uses-group h2 {
		font-family: var(--font-pixel);
		font-size: 12px;
		letter-spacing: 1px;
		color: var(--pink-600);
		margin: 0 0 10px;
		text-transform: lowercase;
	}

	.uses-group ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 10px;
	}

	.uses-item {
		background: var(--lilac-100);
		border: 1px solid var(--lilac-300);
		border-radius: 4px;
		padding: 10px 12px;
	}

	.uses-item__name {
		font-family: var(--font-screen);
		font-size: 18px;
		color: var(--ink);
		margin: 0 0 2px;
	}

	.uses-item__detail {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--ink-soft);
		margin: 0 0 4px;
	}

	.uses-item__why {
		font-family: var(--font-screen);
		font-size: 15px;
		color: var(--ink);
		margin: 0;
	}

	.uses-item__why::before {
		content: '› ';
		color: var(--pink-500);
	}

	.uses-item a {
		color: var(--pink-500);
		text-decoration: underline;
	}

	.tools-lede {
		border-left: 3px solid var(--pink-400);
		padding: 0.4rem 0.75rem;
		margin: 0.75rem 0 1rem;
		background: var(--pink-50);
		font-size: 0.92rem;
	}
	.tools-group {
		margin-bottom: 1.25rem;
	}
	.tools-group h3 {
		font-family: var(--font-screen, monospace);
		color: var(--pink-600);
		font-size: 0.95rem;
		margin: 0 0 0.35rem;
		text-transform: lowercase;
		letter-spacing: 0.04em;
	}
	.tools-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.tools-list li {
		display: grid;
		grid-template-columns: 10rem 1fr;
		gap: 0.4rem 0.75rem;
		padding: 0.25rem 0;
		border-bottom: 1px dashed var(--pink-200);
		font-size: 0.88rem;
	}
	.tools-list li:last-child {
		border-bottom: 0;
	}
	.tools-list .tool-id {
		font-family: var(--font-mono);
		color: var(--ink);
	}
	.tools-list .tool-id a {
		color: var(--pink-600);
		text-decoration: none;
	}
	.tools-list .tool-id a:hover {
		text-decoration: underline;
	}
	.tools-list .tool-tag {
		color: var(--ink-soft);
	}
	.tools-hint {
		font-size: 0.8rem;
		color: var(--ink-soft);
		margin: 0 0 1rem;
	}
	.tools-hint code {
		font-family: var(--font-mono);
		background: var(--pink-50);
		padding: 0.05rem 0.3rem;
		border-radius: 2px;
	}

	@media (max-width: 520px) {
		.tools-list li {
			grid-template-columns: 1fr;
			gap: 0.1rem;
		}
	}
</style>

<h1>/uses</h1>

<p class="uses__intro">
	the gear that survives selection pressure. updated when i replace something, not when i think about
	replacing something.
</p>

<h2>ai-native cli stack</h2>
<p class="tools-lede">
	every tool here is chosen because agents and i consume the same interfaces — machine-parseable
	output, deterministic behavior, per-project scoping. most look like "modern cli alternatives,"
	but the real selection pressure is <em>this works with ai pair programming</em>.
</p>
<p class="tools-hint">
	terminal tip: run <code>tools</code> for the overview, or <code>tools &lt;name&gt;</code> (e.g.
	<code>tools ripgrep</code>) for per-tool rationale + examples.
</p>
{
	toolsByCategory.map((group) => (
		<section class="tools-group">
			<h3>{group.title}</h3>
			<ul class="tools-list">
				{group.items.map((t) => (
					<li>
						<span class="tool-id">
							{t.docsUrl ? (
								<a href={t.docsUrl} target="_blank" rel="noopener">
									{t.name}
								</a>
							) : (
								t.name
							)}
						</span>
						<span class="tool-tag">{t.tagline}</span>
					</li>
				))}
			</ul>
		</section>
	))
}

<h2>physical stack</h2>

<section class="chimera" aria-label="chimera server specs">
	<header class="chimera__header">
		<span class="chimera__name">chimera</span>
		<span class="chimera__role">{chimera.role}</span>
	</header>
	<dl class="chimera__specs">
		{
			chimera.specs.map((s) => (
				<>
					<dt>{s.k}</dt>
					<dd>{s.v}</dd>
				</>
			))
		}
	</dl>
</section>

{
	gear.map((g) => (
		<section class="uses-group">
			<h2>{g.title}</h2>
			<ul>
				{g.items.map((item) => (
					<li class="uses-item">
						<p class="uses-item__name">
							{item.url ? (
								<a href={item.url} target="_blank" rel="noopener">
									{item.name}
								</a>
							) : (
								item.name
							)}
						</p>
						{item.detail && <p class="uses-item__detail">{item.detail}</p>}
						{item.why && <p class="uses-item__why">{item.why}</p>}
					</li>
				))}
			</ul>
		</section>
	))
}
