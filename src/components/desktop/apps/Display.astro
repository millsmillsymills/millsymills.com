---
import { themes } from '../../../data/themes';
import { wallpapers } from '../../../data/wallpapers';
---

<style>
	.display {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.display__intro {
		font-family: var(--font-screen);
		font-size: 16px;
		color: var(--ink-muted);
		margin: 0;
	}

	.display__section {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.display__heading {
		font-family: var(--font-pixel);
		font-size: 10px;
		letter-spacing: 1px;
		color: var(--neon-pink);
		margin: 0;
		text-transform: lowercase;
	}

	.display__grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 14px;
	}

	.display__tile {
		all: unset;
		cursor: var(--c-pointer);
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 6px;
		background: var(--bg-deep);
		border: 2px solid var(--lilac-300);
		border-radius: 6px;
		transition: border-color 120ms ease, transform 120ms ease;
	}

	.display__tile:hover,
	.display__tile:focus-visible {
		border-color: var(--neon-cyan);
		transform: translateY(-1px);
	}

	.display__tile--active {
		border-color: var(--neon-pink);
		box-shadow: 2px 2px 0 var(--neon-cyan);
	}

	.display__tile--active::after {
		content: '✓ active';
		font-family: var(--font-pixel);
		font-size: 8px;
		color: var(--neon-pink);
		letter-spacing: 1px;
		align-self: flex-end;
	}

	.display__thumb {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 3px;
		image-rendering: -webkit-optimize-contrast;
	}

	.display__label {
		font-family: var(--font-pixel);
		font-size: 9px;
		color: var(--neon-cyan);
		letter-spacing: 1px;
		text-align: center;
		text-transform: lowercase;
	}

	.display__swatches {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 4px;
		min-height: 70px;
		border: 1px solid var(--border);
		border-radius: 3px;
		overflow: hidden;
	}

	.display__swatch {
		min-width: 0;
	}

	.display__description {
		font-family: var(--font-screen);
		font-size: 13px;
		line-height: 1.15;
		color: var(--ink-muted);
		text-align: center;
	}
</style>

<article class="display">
	<p class="display__intro">
		pick a theme + wallpaper. choices survive reload.
	</p>

	<section class="display__section" aria-labelledby="display-theme-heading">
		<h2 id="display-theme-heading" class="display__heading">theme</h2>
		<ul class="display__grid">
			{
				themes.map((theme) => (
					<li>
						<button
							type="button"
							class="display__tile"
							data-theme-choice={theme.id}
							aria-pressed="false"
							aria-label={`set theme: ${theme.label}`}
						>
							<span class="display__swatches" aria-hidden="true">
								{theme.swatches.map((swatch) => (
									<span class="display__swatch" style={`background: ${swatch}`} />
								))}
							</span>
							<span class="display__label">{theme.label}</span>
							<span class="display__description">{theme.description}</span>
						</button>
					</li>
				))
			}
		</ul>
	</section>

	<section class="display__section" aria-labelledby="display-wallpaper-heading">
		<h2 id="display-wallpaper-heading" class="display__heading">wallpaper</h2>
		<ul class="display__grid">
			{
				wallpapers.map((w) => (
					<li>
						<button
							type="button"
							class="display__tile"
							data-wallpaper={w.id}
							aria-pressed="false"
							aria-label={`set wallpaper: ${w.label}`}
						>
							<img
								class="display__thumb"
								src={w.thumbnail}
								alt=""
								aria-hidden="true"
								loading="lazy"
								decoding="async"
							/>
							<span class="display__label">{w.label}</span>
						</button>
					</li>
				))
			}
		</ul>
	</section>
</article>

<script>
	import '../../../scripts/display-picker';
</script>
