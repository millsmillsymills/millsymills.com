---
interface Props {
	target: string;
	label: string;
	glyph: string;
}

const { target, label, glyph } = Astro.props;
---

<li>
	<button type="button" class="desktop-icon" data-open-window={target}>
		<span class="desktop-icon__glyph" aria-hidden="true">{glyph}</span>
		<span class="desktop-icon__label">{label}</span>
	</button>
</li>
