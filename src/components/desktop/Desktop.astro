---
import DesktopIcon from './DesktopIcon.astro';
import Window from './Window.astro';
import Taskbar from './Taskbar.astro';
import About from './apps/About.astro';
import Resume from './apps/Resume.astro';
import Photos from './apps/Photos.astro';
import Mail from './apps/Mail.astro';
import Flags from './apps/Flags.astro';
import Terminal from './apps/Terminal.astro';
import Music from './apps/Music.astro';
import Memes from './apps/Memes.astro';
import Trash from './apps/Trash.astro';
import Projects from './apps/Projects.astro';
import Uses from './apps/Uses.astro';
import Privacy from './apps/Privacy.astro';
import Security from './apps/Security.astro';
import Incidents from './apps/Incidents.astro';
import VSCode from './apps/VSCode.astro';
import Display from './apps/Display.astro';
import { apps } from '../../data/apps';

const contentFor = (id: string) => {
	switch (id) {
		case 'about':
			return About;
		case 'resume':
			return Resume;
		case 'photos':
			return Photos;
		case 'mail':
			return Mail;
		case 'terminal':
			return Terminal;
		case 'flags':
			return Flags;
		case 'music':
			return Music;
		case 'memes':
			return Memes;
		case 'trash':
			return Trash;
		case 'projects':
			return Projects;
		case 'uses':
			return Uses;
		case 'privacy':
			return Privacy;
		case 'security':
			return Security;
		case 'incidents':
			return Incidents;
		case 'vscode':
			return VSCode;
		case 'display':
			return Display;
		default:
			return null;
	}
};
---

<main class="desktop" id="desktop">
	<span class="desktop__sparkle-layer" aria-hidden="true"></span>
	<ul class="desktop__icons">
		{apps.filter((a) => !a.hidden).map((a) => <DesktopIcon target={a.id} label={a.label} glyph={a.glyph} iconUrl={a.iconUrl} />)}
	</ul>

	{
		/* Render every window — including hidden apps — so direct-hit
		   permalinks (`/flags/`, `/mail/`, `/vscode/`) still open the
		   right window via the `data-initial-open` server-render path.
		   Only the *advertising* surfaces (icons + start menu) honor
		   `hidden`. */
		apps.map((a) => {
			const Content = contentFor(a.id);
			return (
				<Window id={a.id} title={a.title} x={a.x} y={a.y} width={a.width} height={a.height}>
					{Content && <Content />}
				</Window>
			);
		})
	}

	<Taskbar menu={apps.filter((a) => !a.hidden).map((a) => ({ target: a.id, label: a.label }))} />
</main>
