---
import DesktopIcon from './DesktopIcon.astro';
import Window from './Window.astro';
import Taskbar from './Taskbar.astro';
import About from './apps/About.astro';
import Resume from './apps/Resume.astro';
import Photos from './apps/Photos.astro';
import Mail from './apps/Mail.astro';
import Stub from './apps/Stub.astro';

const apps = [
	{ id: 'about', label: 'about.me', glyph: '🪪', title: 'about.exe' },
	{ id: 'resume', label: 'resume', glyph: '📄', title: 'resume.txt' },
	{ id: 'photos', label: 'photos', glyph: '🖼️', title: 'photos/' },
	{ id: 'terminal', label: 'terminal', glyph: '⌨️', title: 'mills@millsymills:~' },
	{ id: 'music', label: 'music', glyph: '💿', title: 'winamp.exe' },
	{ id: 'memes', label: 'memes', glyph: '🗂️', title: 'memes/' },
	{ id: 'mail', label: 'mail', glyph: '✉️', title: 'mail.exe' },
	{ id: 'trash', label: 'trash', glyph: '🗑️', title: 'recycle.bin' },
];
---

<main class="desktop" id="desktop">
	<ul class="desktop__icons">
		{apps.map((a) => <DesktopIcon target={a.id} label={a.label} glyph={a.glyph} />)}
	</ul>

	<Window id="about" title="about.exe" x={140} y={60} width={620} height={460}>
		<About />
	</Window>

	<Window id="resume" title="resume.txt" x={200} y={120} width={680} height={520}>
		<Resume />
	</Window>

	<Window id="photos" title="photos/" x={260} y={140} width={520} height={460}>
		<Photos />
	</Window>

	<Window id="mail" title="mail.exe" x={300} y={160} width={460} height={300}>
		<Mail />
	</Window>

	<Window id="terminal" title="mills@millsymills:~" x={180} y={120} width={620} height={420}>
		<Stub title="terminal" note="phase 2 — mock REPL with whoami, ls, cat, sudo, and easter eggs." />
	</Window>

	<Window id="music" title="winamp.exe" x={220} y={180} width={420} height={260}>
		<Stub title="music" note="phase 3 — chiptune player with skin." />
	</Window>

	<Window id="memes" title="memes/" x={240} y={200} width={520} height={420}>
		<Stub
			title="memes"
			note="phase 3 — image gallery starting with the hac meme. drop into public/images/memes/."
		/>
	</Window>

	<Window id="trash" title="recycle.bin" x={280} y={220} width={420} height={260}>
		<Stub title="trash" note="empty. (or is it?)" />
	</Window>

	<Taskbar menu={apps.map((a) => ({ target: a.id, label: a.label }))} />
</main>
