---
interface MenuItem {
	target: string;
	label: string;
}

interface Props {
	menu: MenuItem[];
}

const { menu } = Astro.props;
---

<nav class="taskbar" aria-label="taskbar">
	<button type="button" class="taskbar__start" aria-haspopup="menu" aria-expanded="false">
		<span aria-hidden="true">★</span>
		<span>start</span>
	</button>
	<ul class="taskbar__items" aria-label="open windows"></ul>
	<span class="now-playing" data-now-playing aria-live="polite" hidden>
		<span class="now-playing__note" aria-hidden="true">♪</span>
		<span data-now-playing-text>—</span>
	</span>
	<span class="taskbar__clock motif-chrom" aria-label="current time">--:--</span>
</nav>

<script>
	import '../../scripts/taskbar-now-playing';
</script>

<div class="start-menu" hidden role="menu" aria-label="start menu">
	<div class="start-menu__header motif-chrom">mills@millsymills:~$</div>
	<ul class="start-menu__list">
		{
			menu.map((item) => (
				<li>
					<button
						type="button"
						class="start-menu__item"
						data-open-window={item.target}
						role="menuitem"
					>
						{item.label}
					</button>
				</li>
			))
		}
		<li class="start-menu__sep" aria-hidden="true"></li>
		<li>
			<button
				type="button"
				class="start-menu__item start-menu__item--danger"
				data-reset-trigger
				role="menuitem"
			>
				⟲ reset desktop
			</button>
		</li>
	</ul>
</div>
