---
import HitCounter from './HitCounter.astro';

interface MenuItem {
	target: string;
	label: string;
}

interface Props {
	menu: MenuItem[];
}

const { menu } = Astro.props;
---

<nav class="taskbar" aria-label="taskbar">
	<button
		type="button"
		class="taskbar__start"
		data-focus-fallback
		aria-haspopup="menu"
		aria-expanded="false"
	>
		<span aria-hidden="true">★</span>
		<span>start</span>
	</button>
	<ul class="taskbar__items" aria-label="open windows"></ul>
	<span class="now-playing" data-now-playing aria-live="polite" hidden>
		<span class="now-playing__note" aria-hidden="true">♪</span>
		<span data-now-playing-text>—</span>
	</span>
	<span
		class="taskbar__online"
		data-taskbar-online
		data-online="true"
		role="status"
		aria-live="polite"
		aria-label="connection: online"
	>
		<img
			src="/images/icons/vaporwave/online.png"
			alt=""
			width="772"
			height="378"
			decoding="async"
			loading="lazy"
		/>
	</span>
	<button
		type="button"
		class="taskbar__sound"
		data-sound-toggle
		aria-pressed="false"
		aria-label="system sounds: off — click to unmute"
	>
		<img src="/images/vaporwave-ui/buttons/mute.png" alt="sound: off" decoding="async" />
	</button>
	<HitCounter />
	<span class="taskbar__clock motif-chrom" aria-label="current time">--:--</span>
</nav>

<script>
	import '../../scripts/taskbar-now-playing';
	import '../../scripts/taskbar-online';
	import '../../scripts/system-sounds-init';
</script>

<div class="start-menu" hidden role="menu" aria-label="start menu">
	<div class="start-menu__header motif-chrom">mills@millsymills:~$</div>
	<ul class="start-menu__list">
		{
			menu.map((item) => (
				<li>
					<button
						type="button"
						class="start-menu__item"
						data-open-window={item.target}
						role="menuitem"
					>
						{item.label}
					</button>
				</li>
			))
		}
		<li class="start-menu__sep" aria-hidden="true"></li>
		<li>
			<button
				type="button"
				class="start-menu__item start-menu__item--danger"
				data-reset-trigger
				role="menuitem"
			>
				⟲ reset desktop
			</button>
		</li>
	</ul>
</div>
