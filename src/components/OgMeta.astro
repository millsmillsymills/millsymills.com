---
interface Props {
	title: string;
	description?: string | undefined;
	ogUrl?: string | undefined;
	ogImage?: string | undefined;
	ogType?: string | undefined;
	ogSiteName?: string | undefined;
}

const {
	title,
	description,
	ogUrl,
	ogImage,
	ogType = 'website',
	ogSiteName,
} = Astro.props;

function imageMimeType(url: string): string {
	if (/\.jpe?g(\?|#|$)/i.test(url)) return 'image/jpeg';
	if (/\.webp(\?|#|$)/i.test(url)) return 'image/webp';
	if (/\.gif(\?|#|$)/i.test(url)) return 'image/gif';
	if (/\.avif(\?|#|$)/i.test(url)) return 'image/avif';
	return 'image/png';
}
---
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:type" content={ogType} />
{ogSiteName && <meta property="og:site_name" content={ogSiteName} />}
{ogUrl && <meta property="og:url" content={ogUrl} />}
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:type" content={imageMimeType(ogImage)} />}
{ogImage && <meta property="og:image:width" content="1200" />}
{ogImage && <meta property="og:image:height" content="630" />}
{ogImage && <meta property="og:image:alt" content={title} />}
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{ogImage && <meta name="twitter:image" content={ogImage} />}
{ogImage && <meta name="twitter:image:alt" content={title} />}
