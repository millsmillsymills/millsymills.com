# Copy to infra/terraform.tfvars and fill in real values. The
# terraform.tfvars file itself is gitignored (see top-level .gitignore).
#
# NOTE — this file is auto-loaded by terraform on every run regardless of
# which stack `scripts/tf.sh` is targeting. Only put values here that are
# *stack-agnostic* (e.g., github_repo when you operate a single stack).
#
# Stack-specific SECRETS — most commonly the per-stack
# `protonmail_verification_token` — belong in
# `infra/stacks/<stack>.secrets.tfvars` (also gitignored). That file is
# auto-loaded last by `scripts/tf.sh` so its values override anything set
# here. Putting a stack-specific secret in *this* shared file when you
# operate more than one stack will silently apply one stack's value to
# the other, rewriting live DNS on apply. See CLAUDE.md "Email
# (ProtonMail)" and PRs #572 / #574 for the full rationale.

# REQUIRED. GitHub repo (owner/name) allowed to assume the deploy
# role via OIDC. There is deliberately no default so a fork can't
# accidentally let the upstream repo (millsmillsymills/millsymills.com)
# deploy into its AWS account.
github_repo = "owner/repo"

# Optional — branch on `github_repo` allowed to assume the deploy
# role. Defaults to "main".
# deploy_branch = "main"

# GitHub token used by the `github` provider to manage the `main`
# branch protection rule (see infra/github_branch_protection.tf).
# Required for every plan/apply once the resource is in state — Terraform
# refreshes all managed resources on each run, so a blank token fails on
# the GitHub API refresh with `401 Bad credentials`.
#
# Recommended: a fine-grained personal access token scoped to this
# single repo, with `Repository permissions → Administration:
# Read and write` (no other scopes — branch protection is the only
# resource managed). Pass at apply time via:
#
#   TF_VAR_github_token=$(gh auth token) ./scripts/tf.sh millsymills apply
#
# so the token never lands in tfvars on disk. Setting it here works too
# (terraform.tfvars is gitignored) but loses the rotation property.
#
# Note: `$(gh auth token)` returns the gh CLI's own OAuth token — broad
# scope (whatever the CLI was authenticated with), no per-token expiry,
# rotated only when you re-auth the CLI. Fine for one-off applies, but
# loses the per-PAT rotation property of a fine-grained PAT (explicit
# expiry, scoped to a single repo, revocable on its own). For routine
# ops, export a fine-grained PAT as `TF_VAR_github_token` instead.
# github_token = ""

# ProtonMail verification token: put it in
# `infra/stacks/<stack>.secrets.tfvars`, NOT here. See CLAUDE.md
# "Email (ProtonMail)". A single-stack deployer could set it here, but
# the multi-stack repo layout silently breaks on apply if a token meant
# for one stack lands in this shared file.

# ProtonMail DKIM selectors are public-by-virtue-of-DNS, not secret.
# They live in the committed `infra/stacks/<stack>.tfvars` (see
# `p41m0n.tfvars` for the existing pattern). Do not duplicate here.

# Mailbox / alias that receives DMARC aggregate reports. Leave blank
# to default to `dmarc@<var.domain>`.
# dmarc_report_address = "dmarc@example.com"

# Mailbox / alias that receives SMTP TLS Reporting (RFC 8460)
# aggregate reports. Leave blank to default to `tls-rpt@<var.domain>`.
# tlsrpt_report_address = "tls-rpt@example.com"

# Mailbox / alias that receives CAA iodef violation reports. Leave
# blank to default to `security@<var.domain>`.
# caa_iodef_address = "security@example.com"

# Mailbox / alias that receives CT log monitoring alerts. Leave blank
# to default to `security@<var.domain>`. Address must confirm the AWS
# SNS subscription email after first apply or alerts go nowhere.
# ct_monitor_alert_address = "security@example.com"

# Extra issuer-name substrings to add to the CT-monitor allow-list
# alongside the always-included "Amazon". Only set this if you begin
# issuing certs from a CA other than ACM.
# ct_monitor_extra_issuers = ["Let's Encrypt"]
