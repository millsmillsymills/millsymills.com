# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Terraform
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/bootstrap-state/.terraform/
infra/bootstrap-state/terraform.tfstate
infra/bootstrap-state/terraform.tfstate.backup
infra/bootstrap-state/errored.tfstate
# `infra/errored.tfstate` is written when an apply aborts mid-flight and the
# remote-state save itself fails (e.g. STS token expiry); it's a recovery
# artifact, not a source of truth. Re-running apply with fresh creds reads
# remote state and reconciles. Never commit it.
infra/errored.tfstate
# NB: non-recursive glob is intentional — infra/stacks/*.tfvars carry per-stack
# config (millsymills, p41m0n) and ARE committed. If a future change makes this
# recursive (e.g. **/*.tfvars), it would silently start ignoring those files.
infra/*.tfvars
!infra/terraform.tfvars.example
# Per-stack secret tokens. Kept separate because terraform auto-loads root
# `infra/terraform.tfvars` for every stack, so any secret put there leaks
# across stacks.
infra/stacks/*.secrets.tfvars

# local-only state (brainstorming scratch, claude scheduled tasks + settings, misc)
.superpowers/
.local/
.claude/

# git worktrees
.worktrees/

# Codebase-review findings docs produced by agent passes — local-only working
# notes; actionable findings get filed as GitHub issues, the doc itself is a
# stale snapshot once that conversion has happened.
docs/reviews/

# Playwright MCP capture (console logs + page snapshots from interactive runs)
.playwright-mcp/

# Playwright test artifacts (per-run traces, screenshots, html report)
test-results/
playwright-report/

# scripts/analytics/run.sh --save destination (future flag, but reserve the path now)
.cache/analytics/
